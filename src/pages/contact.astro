---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageSections from "@/components/PageSections.astro";
import { categories, posts } from "@/data/content";
import { site } from "@/data/site";
import { getPageBySlug, getSiteSettings } from "@/lib/sanity";

const [page, settings] = await Promise.all([getPageBySlug("contact"), getSiteSettings()]);
---

<BaseLayout title={page?.title || "联系"} description={page?.description || "联系睡前历史频道。"} settings={settings}>
  {page?.sections?.length ? (
    <PageSections sections={page.sections} posts={posts} categories={categories} />
  ) : (
    <>
  <section class="page-hero">
    <div class="container page-intro">
      <p class="eyebrow">联系</p>
      <h1>联系频道</h1>
      <p>商务合作、内容勘误、转载授权和听众反馈，都可以通过这里联系。</p>
    </div>
  </section>
  <section>
    <div class="container article-body">
      <p>邮箱：<a href={`mailto:${site.email}`}>{site.email}</a></p>
      <p>外部平台链接目前为占位，正式上线前可替换为 YouTube、Bilibili、小红书或播客平台主页。</p>
      <p>如果你希望提供史料线索或纠错建议，请尽量附上文章标题、具体段落和参考来源。</p>
    </div>
  </section>
    </>
  )}
</BaseLayout>
