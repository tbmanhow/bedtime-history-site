---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { posts } from "@/data/content";
---

<BaseLayout title="搜索" description="搜索睡前历史频道文章。">
  <section class="page-hero">
    <div class="container page-intro">
      <p class="eyebrow">搜索</p>
      <h1>查找文章</h1>
      <p>按标题、摘要、标签或分类关键词筛选内容。</p>
    </div>
  </section>
  <section>
    <div class="container">
      <div class="search-box">
        <input id="searchInput" type="search" placeholder="输入关键词，例如：赤壁、韩信、一战、福州" autocomplete="off" />
      </div>
      <div id="searchResults" class="grid posts-grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
  <script is:inline define:vars={{ posts }}>
    const input = document.querySelector("#searchInput");
    const results = document.querySelector("#searchResults");
    const render = (items) => {
      results.innerHTML = items.map((post) => `
        <article class="card">
          <a href="/articles/${post.slug}/"><img class="card-image" src="${post.image}" alt="${post.title}" loading="lazy"></a>
          <div class="card-body">
            <div class="meta"><span>${post.readMinutes} 分钟阅读</span><span>${post.date}</span></div>
            <h3><a href="/articles/${post.slug}/">${post.title}</a></h3>
            <p>${post.excerpt}</p>
            <div class="meta">${post.tags.slice(0, 3).map((tag) => `<span class="tag">${tag}</span>`).join("")}</div>
          </div>
        </article>
      `).join("");
    };
    input?.addEventListener("input", () => {
      const keyword = input.value.trim().toLowerCase();
      if (!keyword) {
        render(posts);
        return;
      }
      render(posts.filter((post) => [
        post.title,
        post.subtitle,
        post.excerpt,
        post.category,
        post.tags.join(" ")
      ].join(" ").toLowerCase().includes(keyword)));
    });
  </script>
</BaseLayout>
