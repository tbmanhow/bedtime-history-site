---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BuilderPage from "@/components/BuilderPage.astro";
import { getSiteSettings } from "@/lib/sanity";

const settings = await getSiteSettings();
---

<BaseLayout
  title="Builder 首页编辑"
  description="Builder.io 首页可视化编辑入口。"
  settings={settings}
  hideFooter={true}
>
  <BuilderPage fallbackLabel="Builder 首页正在等待配置" />
</BaseLayout>
