---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BuilderPage from "@/components/BuilderPage.astro";
import HomePageContent from "@/components/HomePageContent.astro";
import { categories as fallbackCategories, posts as fallbackPosts, type Category, type Post } from "@/data/content";
import { getAllCategories, getAllPosts, getPageBySlug, getSiteSettings } from "@/lib/sanity";
import { site } from "@/data/site";

const [homePage, settings, posts, categories] = await Promise.all([
  getPageBySlug("home"),
  getSiteSettings(),
  getAllPosts(),
  getAllCategories()
]);

const safePosts = (posts.length ? posts : fallbackPosts) as Post[];
const safeCategories = (categories.length ? categories : fallbackCategories) as Category[];
const featured = safePosts.filter((post: Post) => post.featured);
const heroPost = featured[0] ?? safePosts[0];
const description = homePage?.description || "黑红电影感历史内容站。长文、图片、音频与视频，为睡前听众整理成可反复进入的历史档案。";
const useBuilderHomepage = import.meta.env.BUILDER_HOMEPAGE_ENABLED === "true";
---

<BaseLayout
  title={homePage?.title || site.name}
  description={description}
  image={heroPost.image}
  settings={settings}
  hideFooter={useBuilderHomepage}
>
  {useBuilderHomepage ? (
    <BuilderPage fallbackLabel="Builder 首页正在加载" />
  ) : (
    <HomePageContent heroPost={heroPost} posts={safePosts} categories={safeCategories} />
  )}
</BaseLayout>
